# Copy to ".env.local" for secrets / overrides (PowerShell: Copy-Item .env.example .env.local)
# Never commit .env.local. Public defaults: .env.development (dev) and .env.production (build).

# SmartQueue — from Base44 API reference
VITE_BASE44_APP_ID=69a35c4a7320c1762a3e2af0
# Origin only (no /api). Base URL in docs is https://smartqueue.base44.app/api
VITE_BASE44_APP_BASE_URL=https://smartqueue.base44.app

# Optional legacy alias for the URL above
# VITE_BASE44_BACKEND_URL=

# If your Base44 API reference shows headers.api_key on createClient, set it here (do not commit real keys to git)
VITE_BASE44_API_KEY=
